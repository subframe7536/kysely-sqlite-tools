{
  "name": "kysely-sqlite-tools",
  "version": "1.2.1",
  "private": true,
  "description": "",
  "license": "MIT",
  "author": {
    "name": "subframe7536",
    "email": "1667077010@qq.com"
  },
  "workspaces": [
    "packages/*",
    "playground"
  ],
  "type": "module",
  "scripts": {
    "dev": "bun run --filter \"./packages/dialect*\" dev",
    "build": "bun run --filter \"./packages/dialect*\" build",
    "release": "bun install && bumpp package.json packages/dialect*/package.json",
    "serve": "bun --cwd=playground run dev",
    "publish": "for dir in packages/dialect*; do (cd \"$dir\" && npm publish --provenance --access public); done",
    "test": "bun test ./packages/dialect-generic-sqlite/test/*.test.ts ./packages/dialect-tauri/test/*.test.ts ./packages/dialect-wasm/test/*.test.ts ./packages/dialect-wasqlite-worker/test/*.test.ts ./packages/dialect-bun-worker/test/*.test.ts && bun test --preload ./packages/dialect-sqlite-worker/test/better-sqlite3-preload.ts ./packages/dialect-sqlite-worker/test/*.test.ts",
    "typecheck": "tsc --noEmit",
    "format": "oxfmt",
    "lint": "oxlint",
    "release:package": "bun install && bumpp --no-commit --no-tag --no-push",
    "publish:package": "node ./scripts/publish-package.mjs",
    "qa": "oxlint --fix && oxfmt && tsc --noEmit && bun run test"
  },
  "devDependencies": {
    "@sqlite.org/sqlite-wasm": "3.53.0-build1",
    "@subf/config": "^0.2.1",
    "@subframe7536/type-utils": "^0.2.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/sql.js": "^1.4.11",
    "@vlcn.io/crsqlite-wasm": "^0.16.0",
    "better-sqlite3": "^12.11.1",
    "bumpp": "^11.1.0",
    "bun-types": "^1.3.14",
    "kysely": "^0.28.2",
    "node-sqlite3-wasm": "^0.8.59",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "sql.js": "^1.14.1",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.0"
  },
  "packageManager": "bun@1.2.14"
}
