{
  "name": "kysely-generic-sqlite",
  "version": "2.0.0-beta.7",
  "description": "Generic kysely dialect for SQLite, support run in main thread or worker",
  "keywords": [
    "dialect",
    "kysely",
    "sql",
    "sqlite3",
    "worker"
  ],
  "homepage": "https://github.com/subframe7536/kysely-sqlite-tools/tree/master/packages/dialect-generic-sqlite",
  "bugs": "https://github.com/subframe7536/kysely-sqlite-tools/issues",
  "license": "MIT",
  "author": {
    "name": "subframe7536",
    "email": "1667077010@qq.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/subframe7536/kysely-sqlite-tools.git#master"
  },
  "files": [
    "dist",
    "MIGRATE_TO_V2.md"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "typesVersions": {
    "*": {
      "worker": [
        "./dist/worker.d.mts"
      ],
      "worker-helper-node": [
        "./dist/worker-helper-node.d.mts"
      ],
      "worker-helper-web": [
        "./dist/worker-helper-web.d.mts"
      ]
    }
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./worker": {
      "import": "./dist/worker.mjs",
      "require": "./dist/worker.cjs"
    },
    "./worker-helper-node": {
      "import": "./dist/worker-helper-node.mjs",
      "require": "./dist/worker-helper-node.cjs"
    },
    "./worker-helper-web": {
      "import": "./dist/worker-helper-web.mjs",
      "require": "./dist/worker-helper-web.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "tsdown"
  },
  "devDependencies": {
    "kysely": "catalog:"
  },
  "peerDependencies": {
    "kysely": ">=0.29"
  }
}
